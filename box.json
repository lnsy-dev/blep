{
    "main": "bin/blep",
    "output": "build/blep",
    "chmod": "0755",
    "directories": [
        "src"
    ],
    "files": [
        "LICENSE"
    ],
    "finder": [
        {
            "name": "*.php",
            "in": "src",
            "exclude": []
        },
        {
            "name": "*.css",
            "in": "src/Templates"
        }
    ],
    "compression": "GZ",
    "compactors": [
        "KevinGH\\Box\\Compactor\\Php"
    ],
    "stub": true
}
