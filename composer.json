{
    "name": "lnsy-dev/blep",
    "description": "Business Logic Documentation Generator - Extract @bl-* tags from PHP code and generate clean HTML documentation",
    "type": "library",
    "license": "MIT",
    "keywords": ["documentation", "business-logic", "php", "generator", "static-site", "code-documentation"],
    "homepage": "https://github.com/lnsy-dev/blep",
    "authors": [
        {
            "name": "LNSY",
            "homepage": "https://github.com/lnsy-dev"
        }
    ],
    "support": {
        "issues": "https://github.com/lnsy-dev/blep/issues",
        "source": "https://github.com/lnsy-dev/blep"
    },
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "humbug/box": "^4.0"
    },
    "bin": [
        "bin/blep"
    ],
    "autoload": {
        "psr-4": {
            "Blep\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "bin-dir": "vendor/bin",
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest",
        "build": "box compile"
    }
}
